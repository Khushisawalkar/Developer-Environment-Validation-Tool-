<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.control.ScrollPane?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.nexus.controller.WorkspacesController" styleClass="main-content" spacing="30">
    <padding><Insets top="40" right="50" bottom="40" left="50"/></padding>
    
    <VBox spacing="5">
        <Label text="Workspaces" styleClass="header-title"/>
        <Label text="One-click launch for your development environments." styleClass="header-subtitle"/>
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane-custom" vbarPolicy="AS_NEEDED">
        <FlowPane fx:id="profilesFlowPane" hgap="20" vgap="20" />
    </ScrollPane>
</VBox>
